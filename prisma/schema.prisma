generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") 
}

model Session {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime?
  duration  Int?
  tags      String[]
  note      String?
  createdAt DateTime @default(now())
}